{
  "name": "@irvingdinh/porygon-z",
  "version": "0.1.3",
  "description": "A Slack bot powered by Claude Code for executing AI-assisted tasks in your workspace",
  "author": "Irving Dinh <irving.ding@gmail.com>",
  "license": "MIT",
  "keywords": [
    "slack",
    "slack-bot",
    "claude",
    "claude-code",
    "anthropic",
    "ai-assistant",
    "chatbot",
    "nestjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/irvingdinh/porygon-z.git"
  },
  "homepage": "https://github.com/irvingdinh/porygon-z#readme",
  "bugs": {
    "url": "https://github.com/irvingdinh/porygon-z/issues"
  },
  "bin": {
    "porygon-z": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write --log-level warn \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@slack/bolt": "^4.7.0",
    "handlebars": "^4.7.9",
    "nanoid": "^5.1.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.4.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
